# Lotus CRM Environment Configuration
# Copy to .env and adjust values before deployment

SECRET_KEY=your-super-secret-key-change-in-production
POSTGRES_USER=lotus
POSTGRES_PASSWORD=lotus_secret_change_me
POSTGRES_DB=lotus_crm
DATABASE_URL=postgresql+psycopg://lotus:lotus_secret_change_me@localhost:5432/lotus_crm

APP_PORT=16350
DEFAULT_LANGUAGE=ar
FLASK_DEBUG=0

BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=30

